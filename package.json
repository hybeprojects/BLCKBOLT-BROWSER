{
  "name": "blckbolt-browser",
  "version": "0.1.0",
  "description": "BLCKBOLT-BROWSER: Advanced Developer Privacy Browser (Electron)",
  "main": "main/main.js",
  "scripts": {
    "dev": "next dev renderer",
    "build:renderer": "next build renderer",
    "start": "electron .",
    "build": "npm run build:renderer && electron-builder",
    "lint": "eslint main renderer",
    "typecheck": "cd renderer && tsc --noEmit"
  },
  "author": "hybeprojects",
  "license": "MIT",
  "dependencies": {
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "framer-motion": "^11.2.2",
    "tailwindcss": "^3.4.10",
    "electron-updater": "^6.1.7",
    "socks-proxy-agent": "^8.0.3"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.56.0",
    "typescript": "^5.5.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.2",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39"
  },
  "build": {
    "appId": "com.blckbolt.browser",
    "productName": "BLCKBOLT Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "main/**/*",
      "renderer/out/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "hybeprojects",
        "repo": "BLCKBOLT-BROWSER"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "BLCKBOLT Browser",
      "installerIcon": "main/assets/icon.ico",
      "uninstallerIcon": "main/assets/icon.ico",
      "installerHeaderIcon": "main/assets/icon.ico",
      "displayLanguageSelector": false,
      "license": "LICENSE.txt"
    },
    "protocols": [
      {
        "name": "BLCKBOLT Protocol",
        "schemes": [
          "blckbolt"
        ]
      }
    ],
    "directories": {
      "buildResources": "main/assets"
    },
    "mac": {
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "main/assets/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
