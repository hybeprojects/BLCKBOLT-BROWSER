{
  "name": "blckbolt-browser",
  "version": "0.1.0",
  "description": "BLCKBOLT-BROWSER: Advanced Developer Privacy Browser (Electron)",
  "main": "main/main.js",
  "scripts": {
    "dev": "next dev renderer",
    "build:renderer": "next build renderer",
    "start": "electron .",
    "build": "npm run build:renderer && electron-builder",
    "build:prod": "npm run build:renderer && electron-builder -p never",
    "build:win": "npm run build:renderer && electron-builder --win nsis portable -p never",
    "build:linux": "npm run build:renderer && electron-builder --linux appimage deb -p never",
    "build:mac": "npm run build:renderer && electron-builder --mac dmg zip -p never",
    "build:all": "npm run build:renderer && electron-builder -mwl -p never",
    "lint": "eslint main renderer",
    "typecheck": "cd renderer && tsc --noEmit"
  },
  "author": {
    "name": "hybeprojects",
    "email": "contact@hybe.pro"
  },
  "license": "MIT",
  "dependencies": {
    "next": "14.2.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "framer-motion": "^11.2.2",
    "tailwindcss": "^3.4.10",
    "electron-updater": "^6.1.7",
    "socks-proxy-agent": "^8.0.3"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.56.0",
    "typescript": "^5.5.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.2",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39"
  },
  "build": {
    "appId": "com.blckbolt.browser",
    "productName": "BLCKBOLT Browser",
    "directories": {
      "output": "dist",
      "buildResources": "main/assets"
    },
    "files": [
      "main/**/*",
      "renderer/out/**/*",
      "package.json",
      "!dist"
    ],
    "extraMetadata": {
      "main": "main/main.js"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "hybeprojects",
        "repo": "BLCKBOLT-BROWSER"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BLCKBOLT Browser",
      "installerIcon": "main/assets/icon.ico",
      "uninstallerIcon": "main/assets/icon.ico",
      "installerHeaderIcon": "main/assets/icon.ico",
      "displayLanguageSelector": false,
      "license": "LICENSE.txt",
      "artifactName": "BLCKBOLT-Browser-Setup-${version}.exe"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "main/assets/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Development",
      "maintainer": "hybeprojects <contact@hybe.pro>",
      "icon": "main/assets/icon.png",
      "artifactName": "BLCKBOLT-Browser-${version}-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "BLCKBOLT-Browser-${version}-${arch}.deb",
      "depends": [
        "libappindicator1",
        "libnotify-bin"
      ]
    },
    "protocols": [
      {
        "name": "BLCKBOLT Protocol",
        "schemes": [
          "blckbolt"
        ],
        "role": "Viewer"
      }
    ],
    "directories": {
      "buildResources": "main/assets"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "main/assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true
    }
  }
}
